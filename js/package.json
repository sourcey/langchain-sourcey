{
  "name": "langchain-sourcey",
  "version": "0.1.1",
  "description": "LangChain retriever for Ask AI over published Sourcey docs sites.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Kam Low",
  "homepage": "https://sourcey.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sourcey/langchain-sourcey.git",
    "directory": "js"
  },
  "bugs": {
    "url": "https://github.com/sourcey/langchain-sourcey/issues"
  },
  "keywords": [
    "langchain",
    "sourcey",
    "retriever",
    "rag",
    "documentation"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "input": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "@langchain/core": "^1.0.0"
  },
  "devDependencies": {
    "@langchain/openai": "^1.0.2",
    "@langchain/core": "^1.1.41",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run"
  }
}
